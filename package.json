{
  "name": "headhunt-survival-bot",
  "version": "2.0.0",
  "description": "Discord bot for HeadHunt Survival — server layout setup and portal sync foundation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "deploy:website": "cd website && vercel --prod"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "discord",
    "minecraft",
    "headhunt",
    "survival"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
