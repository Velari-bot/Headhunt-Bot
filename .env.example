# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your Discord server (guild) ID
GUILD_ID=your_guild_id_here

# Optional: restrict slash command registration to one guild (recommended during setup)
# Leave empty to register globally (takes up to 1 hour to propagate)
CLIENT_ID=1523433446586847262

# Role assigned on join — pre-server limited access (Discord role ID)
JOIN_ROLE_ID=1523436417148260512

# Set to false only if Server Members Intent is disabled (disables auto join role)
ENABLE_GUILD_MEMBERS=true

# Minecraft Bedrock Server
SERVER_IP=your.server.ip.here
SERVER_PORT=19132
