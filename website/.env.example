# Database — Neon/Supabase/Railway Postgres connection string
DATABASE_URL=""

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Discord OAuth (https://discord.com/developers/applications → OAuth2)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Auth.js base URL — http://localhost:3000 for dev; production URL when deployed
AUTH_URL=http://localhost:3000

# Shared secret for Minecraft server API routes — must match bds behavior pack config.js
MINECRAFT_SERVER_SECRET=""

# Public site config (hostname/IP only — no https:// prefix)
NEXT_PUBLIC_SERVER_IP=""
NEXT_PUBLIC_SERVER_PORT="19132"
NEXT_PUBLIC_DISCORD_INVITE_URL=""
NEXT_PUBLIC_DISCORD_GUILD_ID=""
