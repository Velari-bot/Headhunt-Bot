# Database — Neon Postgres
# Get from: Neon Dashboard → your project → Connection string → copy (include ?sslmode=require)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Discord OAuth (from https://discord.com/developers/applications)
# Use the same application as your bot, or create a separate OAuth app
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Auth.js
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Minecraft server API authentication
MINECRAFT_SERVER_SECRET=super_private_key_change_me

# Public site config
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite
NEXT_PUBLIC_SERVER_IP=your.server.ip.here
NEXT_PUBLIC_SERVER_PORT=19132
